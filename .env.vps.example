# =============================================================================
# VPS deployment — environment variables for docker-compose.vps.yml
# =============================================================================
# Copy to .env.vps and fill in your values:
#   cp .env.vps.example .env.vps
#
# Restart after edits:
#   docker compose -f docker-compose.vps.yml restart archon

# ---------------------------------------------------------------------------
# AI assistant — at least one auth method required
# ---------------------------------------------------------------------------
# Option 1: Subscription (Max/Team/Enterprise) — run `claude /login` inside
#            the container after first boot to complete OAuth.
CLAUDE_USE_GLOBAL_AUTH=true

# Option 2: API key or OAuth token (uncomment one)
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=...

# Option 3: Third-party provider (e.g. Z.AI devpack)
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# Default assistant (claude | codex)
DEFAULT_AI_ASSISTANT=claude

# ---------------------------------------------------------------------------
# Telegram (primary chat platform)
# ---------------------------------------------------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Restrict who can talk to the bot (optional, comma-separated user IDs)
# Get your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=

# stream = edits messages in real-time; batch = sends complete response
TELEGRAM_STREAMING_MODE=stream

# ---------------------------------------------------------------------------
# Slack (optional — uncomment and fill to enable)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USER_IDS=
# SLACK_STREAMING_MODE=batch

# ---------------------------------------------------------------------------
# Discord (optional — uncomment and fill to enable)
# ---------------------------------------------------------------------------
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USER_IDS=
# DISCORD_STREAMING_MODE=batch

# ---------------------------------------------------------------------------
# GitHub (optional — for cloning private repos, creating PRs)
# ---------------------------------------------------------------------------
# GH_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Must be 3000 to match the image's EXPOSE and healthcheck.
PORT=3000
