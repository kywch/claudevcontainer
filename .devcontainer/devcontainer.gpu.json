{
  "name": "Claude Code Sandbox (GPU)",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--init",
    "--gpus=all",
    "--device=/dev/dri",
    "--env=NVIDIA_DRIVER_CAPABILITIES=graphics,compute,utility"
  ],
  "forwardPorts": [3001, "9000-9100"],
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.enablePersistentSessions": true,
        "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
        "remote.autoForwardPorts": false,
        "remote.restoreForwardedPorts": false
      }
    }
  },
  "remoteUser": "agent",
  "overrideCommand": false,
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.claude ${localEnv:HOME}/.codex ${localEnv:HOME}/.gemini ${localEnv:HOME}/.forge ${localEnv:HOME}/.ssh ${localEnv:HOME}/.config/Code/CachedExtensionVSIXs ${localEnv:HOME}/.config/VSCodium/CachedExtensionVSIXs",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-home-${devcontainerId},target=/home/agent/.claude,type=volume",
    "source=codex-home-${devcontainerId},target=/home/agent/.codex,type=volume",
    "source=gemini-home-${devcontainerId},target=/home/agent/.gemini,type=volume",
    "source=forge-home-${devcontainerId},target=/home/agent/.forge,type=volume",
    "source=gh-config-${devcontainerId},target=/home/agent/.config/gh,type=volume",
    "source=${localEnv:HOME}/.claude,target=/mnt/host-claude,type=bind,readonly",
    "source=${localEnv:HOME}/.codex,target=/mnt/host-codex,type=bind,readonly",
    "source=${localEnv:HOME}/.gemini,target=/mnt/host-gemini,type=bind,readonly",
    "source=${localEnv:HOME}/.forge,target=/mnt/host-forge,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/mnt/host-ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.config/Code/CachedExtensionVSIXs,target=/mnt/host-vscode-vsix-cache,type=bind,readonly",
    "source=${localEnv:HOME}/.config/VSCodium/CachedExtensionVSIXs,target=/mnt/host-vscodium-vsix-cache,type=bind,readonly",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/agent/.claude",
    "CLAUDE_BIN_PATH": "/home/agent/.bun/bin/claude",
    "ARCHON_HOME": "/workspace/.archon",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "graphics,compute,utility"
  },
  "postAttachCommand": "bash .devcontainer/install-openai-chatgpt-vsix.sh",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "portsAttributes": {
    "3001": { "label": "Vite Dev Server" },
    "9000-9100": { "label": "App Services" }
  }
}
